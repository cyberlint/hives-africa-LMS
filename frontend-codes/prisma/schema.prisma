generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String   @id
  name                   String
  email                  String
  emailVerified          Boolean  @default(false)
  image                  String?
  bio                    String?
  website                String?
  // ---  Onboarding Fields ---
  hasCompletedOnboarding Boolean  @default(false)
  primaryLanguage        String   @default("English")
  localLanguage          String?
  jobTitle               String?
  careerInterests        String[] @default([])
  learningIntent         String?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @default(now()) @updatedAt
  sessions         Session[]
  accounts         Account[]
  courses          Course[]
  enrollments      Enrollment[]
  lessonProgress   LessonProgress[]
  userAchievements UserAchievement[]
  wishlist         Wishlist[]

  role         String?
  banned       Boolean?       @default(false)
  banReason    String?
  banExpires   DateTime?
  payments     Payment[]
  CourseReview CourseReview[]
  events       Event[]

  createdActivities Activity[]      @relation("ActivityCreator")
  participations    Participation[]
  submissions       Submission[]    @relation("UserSubmissions")
  teamMemberships   TeamMember[]

  // Review Engine Relations
  assignedReviews ReviewAssignment[] @relation("AssignedReviews") // <--- NEW ADDITION
  reviewsGiven    Review[]           @relation("ReviewsGiven")

  // Value & Credibility Track
  earnedKSBs       UserKSB[]
  reputationLedger ReputationTransaction[]
  portfolio        PortfolioItem[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Course {
  id               String       @id @default(uuid())
  title            String
  description      String
  fileKey          String
  price            Float
  originalPrice    Float?
  registrationFee  Float?       @default(0)
  duration         Int // duration in hours
  level            CourseLevel  @default(Beginner)
  category         String
  shortdescription String
  slug             String       @unique
  status           CourseStatus @default(Draft)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @default(now()) @updatedAt
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  module        Module[]
  enrollments   Enrollment[]
  payments      Payment[]
  wishlistItems Wishlist[]
  reviews       CourseReview[]

  programs   ProgramCourse[]
  activities Activity[]
}

enum CourseLevel {
  Beginner
  Intermediate
  Advanced
}

enum CourseStatus {
  Draft
  InReview
  Published
  Archived
}

model CourseReview {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Module {
  id        String   @id @default(uuid())
  title     String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  courseId  String
  lessons   Lesson[]
  Course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Lesson {
  id             String           @id @default(uuid())
  title          String
  description    String?
  thumbnailKey   String?
  videoKey       String?
  position       Int
  type           LessonType       @default(Video)
  content        String?
  duration       Int?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  moduleId       String
  documentKey    String?
  quizConfig     Json?
  attachments    Attachment[]
  Module         Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]
}

enum LessonType {
  Video
  Document
  Notebook
  Quiz
  Resource
}

model Attachment {
  id          String   @id @default(uuid())
  title       String
  description String?
  type        String
  url         String
  fileSize    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lessonId    String
  Lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id               String        @id @default(uuid())
  enrolledAt       DateTime      @default(now())
  completedAt      DateTime?
  progress         Float         @default(0)
  userId           String
  courseId         String
  paymentReference String?
  paymentStatus    PaymentStatus @default(Pending)
  paymentAmount    Float?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  paymentId        String?       @unique
  Course           Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  payment          Payment?      @relation(fields: [paymentId], references: [id])
  User             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

enum PaymentStatus {
  Pending
  Completed
  Failed
  Refunded
}

model LessonProgress {
  id          String    @id @default(uuid())
  completed   Boolean   @default(false)
  completedAt DateTime?
  currentTime Int?
  userId      String
  lessonId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  score       Float?
  Lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  User        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model Payment {
  id            String        @id @default(uuid())
  reference     String        @unique
  amount        Float
  currency      String        @default("NGN")
  status        PaymentStatus @default(Pending)
  paymentMethod String?
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  userId        String
  courseId      String
  enrollment    Enrollment?
  course        Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
}

model Achievement {
  id          String   @id @default(uuid())
  title       String
  description String
  icon        String
  category    String
  points      Int
  rarity      String
  isSecret    Boolean  @default(false)
  steps       String[] // Stored as array of strings
  maxProgress Int      @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  achievementId String
  unlockedAt    DateTime?
  progress      Int         @default(0)
  isUnlocked    Boolean     @default(false)

  @@unique([userId, achievementId])
}

model Wishlist {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId  String
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model Event {
  id               String        @id @default(uuid())
  title            String
  shortdescription String
  description      String
  startdate        DateTime
  enddate          DateTime
  imageKey         String?
  venue            EventVenue    @default(NextHive)
  url              String?
  eventCategory    EventCategory @default(Tutorial)
  isOnline         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum EventVenue {
  NextHive
  Google_Meet
  Zoom
  Microsoft_Teams
  Offline
  Hybrid
}

enum EventCategory {
  Hackathon
  Webinar
  Brainstorming_Session
  Networking_Event
  Panel_Discussion
  QandA_Session
  Workshop
  Meetup
  Tutorial
  Lecture
  Study_Group
  Roundtable
  Demo_Day
  Office_Hours
  Competition
  Fireside_Chat
  Certification_Course
  Bootcamp
}

// ================ACTIVITY and PROGRAM==========================
// ==========================================
// 1. CORE GROUPING
// ==========================================

model Program {
  id          String   @id @default(uuid())
  title       String
  shortdescription String
  description String
  fileKey     String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses    ProgramCourse[]
  activities Activity[]
}

model ProgramCourse {
  programId   String
  courseId    String
  isMandatory Boolean @default(true)

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([programId, courseId])
}

// ==========================================
// 2. THE ACTIVITY ENGINE
// ==========================================

model Activity {
  id          String             @id @default(uuid())
  title       String
  description String?
  type        ActivityType
  status      ActivityStatus     @default(Draft)
  visibility  ActivityVisibility @default(Public)
  difficulty  ActivityDifficulty @default(Intermediate)

  points      Int       @default(0)
  isMandatory Boolean   @default(false)
  startDate   DateTime?
  deadline    DateTime?

  // Relations
  courseId  String?
  programId String?
  creatorId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  program Program? @relation(fields: [programId], references: [id], onDelete: SetNull)
  creator User     @relation("ActivityCreator", fields: [creatorId], references: [id])

  requirements   ActivityRequirement[]
  participations Participation[]
  submissions    Submission[]
  ksbs           ActivityKSB[]
  teams          Team[] //Teams belong to an activity
}

enum ActivityType {
  // Builder Track
  Project
  Task
  Capstone
  Case_Study
  Client_Simulation

  // Collaborative & Competitive Track
  Challenge
  Hackathon
  Datathon
  Team_Project
  Open_Source_Contribution

  // Community & Leadership Track
  Event_Hosting
  Event_Participation
  Study_Group_Leadership
  Mentorship
  Peer_Review

  // Creator & Knowledge Track
  Community_Contribution
  Tutorial_Creation
  Content_Translation
  Research
  Article_Publication
}

enum ActivityStatus {
  Draft
  Published
  Active
  Completed
  Archived
}

enum ActivityVisibility {
  Public
  Private
  Connections_Only
  Program_Only
  Invite_Only
}

enum ActivityDifficulty {
  Beginner
  Intermediate
  Advanced
  Expert
}

model ActivityRequirement {
  id         String          @id @default(uuid())
  activityId String
  type       RequirementType
  config     Json?
  createdAt  DateTime        @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

enum RequirementType {
  File_Upload
  GitHub_Repo
  Video_Link
  Text_Report
  Peer_Reviews
  Host_An_Online_Event
  Event_Attendance
  Live_Demo
}

// ==========================================
// 3. COLLABORATION & PARTICIPATION (V2 Fixes)
// ==========================================

model Team {
  id          String   @id @default(uuid())
  name        String
  description String?
  activityId  String //Team bound to Activity
  createdAt   DateTime @default(now())

  activity       Activity        @relation(fields: [activityId], references: [id], onDelete: Cascade)
  members        TeamMember[]
  submissions    Submission[]
  participations Participation[]
}

model TeamMember {
  id       String   @id @default(uuid())
  teamId   String
  userId   String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Participation {
  id         String            @id @default(uuid())
  userId     String
  activityId String
  teamId     String? // Links user's participation to their team
  role       ParticipationRole @default(Participant)
  progress   Float             @default(0)
  joinedAt   DateTime          @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity    Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  team        Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  submissions Submission[] // Link submissions directly to the participation instance

  @@unique([userId, activityId])
}

enum ParticipationRole {
  Participant
  Reviewer
  Mentor
  Organizer
}

// ==========================================
// 4. SUBMISSION & REVIEW ENGINE
// ==========================================

model Submission {
  id              String           @id @default(uuid())
  activityId      String
  userId          String? // Note: App logic MUST enforce (userId OR teamId)
  teamId          String?
  participationId String?
  content         Json
  status          SubmissionStatus @default(Draft)
  submittedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  activity      Activity       @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user          User?          @relation("UserSubmissions", fields: [userId], references: [id], onDelete: Cascade)
  team          Team?          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  participation Participation? @relation(fields: [participationId], references: [id], onDelete: SetNull)

  reviews     Review[]
  assignments ReviewAssignment[] // Links to the distribution engine
  portfolio   PortfolioItem?

  @@index([activityId])
}

enum SubmissionStatus {
  Draft
  Submitted
  Under_Review
  Revision_Required
  Approved
  Rejected
}

// The Distribution Engine Table
model ReviewAssignment {
  id           String           @id @default(uuid())
  submissionId String
  reviewerId   String
  status       AssignmentStatus @default(Pending)
  assignedAt   DateTime         @default(now())
  expiresAt    DateTime? // To handle reviewers who don't complete the task

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer   User       @relation("AssignedReviews", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([submissionId, reviewerId])
}

enum AssignmentStatus {
  Pending
  Accepted
  Declined
  Completed
  Expired
}

model Review {
  id           String     @id @default(uuid())
  submissionId String
  reviewerId   String
  type         ReviewType @default(Peer)
  score        Float?
  feedback     String?
  rubricScores Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer   User       @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
}

enum ReviewType {
  Peer
  Instructor
  Mentor
}

// ==========================================
// 5. VALUE LAYER: KSBs, Reputation & Portfolio
// ==========================================

model KSB {
  id          String   @id @default(uuid())
  title       String
  description String?
  type        KSBType
  createdAt   DateTime @default(now())

  activities ActivityKSB[]
  earnedBy   UserKSB[]
}

enum KSBType {
  Knowledge
  Skill
  Behavior
}

model ActivityKSB {
  activityId String
  ksbId      String
  weight     Float? @default(1.0)

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  ksb      KSB      @relation(fields: [ksbId], references: [id], onDelete: Cascade)

  @@id([activityId, ksbId])
}

model UserKSB {
  userId   String
  ksbId    String
  earnedAt DateTime @default(now())
  sourceId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  ksb  KSB  @relation(fields: [ksbId], references: [id], onDelete: Cascade)

  @@id([userId, ksbId])
}

model ReputationTransaction {
  id         String   @id @default(uuid())
  userId     String
  points     Int
  reason     String
  activityId String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PortfolioItem {
  id           String     @id @default(uuid())
  userId       String
  submissionId String     @unique
  title        String
  description  String?
  visibility   Visibility @default(Private)
  createdAt    DateTime   @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

enum Visibility {
  Public
  Private
  Connections_Only
  Program_Only
  Invite_Only
}


// ================ COMMUNICATIONS ENGINE ===============================

model EmailRule {
  id          String   @id @default(uuid())
  eventType   String   // The name of the event it listens for
  templateKey String   // e.g. "submission_approved"
  delay       Int      @default(0) // in minutes

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([eventType])
}

model EmailJob {
  id           String   @id @default(cuid())
  userId       String
  templateKey  String
  payload      Json

  status       String   @default("pending") // pending | processing | sent | failed
  attempts     Int      @default(0)
  lastError    String?

  scheduledAt  DateTime
  sentAt       DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EventLog {
  id        String   @id @default(cuid())
  type      String
  userId    String
  payload   Json
  createdAt DateTime @default(now())
}